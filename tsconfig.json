{
   "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020", "DOM"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "jsx": "react-jsx",
      "strict": true,
      "declaration": true,
      "emitDeclarationOnly": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "rootDir": ".",
      "outDir": "dist-types",
      "baseUrl": ".",
      "paths": {
         "@/*": ["examples/*"]
      }
   },
   "include": ["src", "examples"]
}
