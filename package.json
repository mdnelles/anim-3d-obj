{
   "name": "anim-3d-obj",
   "version": "2.0.4",
   "description": "Configurable 3D object with animated rotations and face content",
   "license": "MIT",
   "author": "mdnelles",
   "sideEffects": [
      "dist/**/*.css",
      "src/styles/obj.css"
   ],
   "main": "dist/index.cjs",
   "module": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.cjs",
         "default": "./dist/index.js"
      }
   },
   "files": [
      "dist",
      "README.md",
      "LICENSE"
   ],
   "peerDependencies": {
      "react": ">=17 || >=18 || >=19",
      "react-dom": ">=17 || >=18 || >=19"
   },
   "devDependencies": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "tsup": "^8.5.0",
      "typescript": "^5.4.0"
   },
   "scripts": {
      "clean": "rm -rf dist",
      "build": "tsup",
      "dev": "tsup --watch",
      "prepublishOnly": "npm run clean && npm run build"
   }
}
